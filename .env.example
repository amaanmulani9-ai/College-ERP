# =================================================================
# College ERP - Configuration Template
# =================================================================
# Copy this file to '.env' in the same directory and fill in your actual keys.
# DO NOT commit the '.env' file to your Git repository.

# Django Security Settings
DEBUG=True
SECRET_KEY=your-long-random-secret-key-here
ALLOWED_HOSTS=*,localhost,127.0.0.1

# Database — Supabase Postgres
# Get these from Supabase Dashboard → Project Settings → Database
POSTGRES_PRISMA_URL=          # pooled (port 6543) — app runtime
POSTGRES_URL_NON_POOLING=     # direct/session (port 5432) — migrations
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=postgres

# Supabase API (optional)
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email SMTP Configurations (Gmail Example)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Google reCAPTCHA Keys (Optional)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Firebase / FCM Push Notifications (Optional)
# Get these from Firebase Console → Project Settings → General
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
# Get this from Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=

# Twilio SMS (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Brevo (Sendinblue) Email API (Optional - fallback if SMTP fails)
BREVO_API_KEY=
